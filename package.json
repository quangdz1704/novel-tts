{
  "name": "novel-tts",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "dev:api": "tsx watch server/index.ts",
    "dev:all": "concurrently -k -n web,api \"npm:dev\" \"npm:dev:api\"",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "typecheck:server": "tsc -p tsconfig.server.json",
    "db:migrate": "tsx server/db/migrate.ts",
    "start:api": "tsx server/index.ts",
    "preview": "vite preview",
    "playwright:install": "npx playwright install --with-deps",
    "test": "vitest",
    "check": "npm run typecheck && npm run typecheck:server && npm test -- --run && npm run build"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "pg": "^8.21.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.14",
    "cheerio": "1.0.0-rc.12",
    "concurrently": "^10.0.3",
    "playwright": "1.44.1",
    "postcss": "^8.4.24",
    "tailwindcss": "^3.4.7",
    "tsx": "^4.22.4",
    "typescript": "^5.1.6",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
